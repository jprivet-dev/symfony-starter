{% extends 'base.html.twig' %}

{% block title %}BcMath\Number V0 (workaround){% endblock %}

{% block body %}
    <h1>BcMath\Number V0 (workaround)</h1>

    {{ form_start(form) }}
    {{ form_row(form.priceA, {label: 'Price A — GreaterThanOrEqual(new BcMath\\Number("0.01"))'}) }}
    {{ form_row(form.priceB, {label: 'Price B — GreaterThanOrEqual("0.01")'}) }}
    {{ form_row(form.priceC, {label: 'Price C — GreaterThanOrEqual(0.01)'}) }}
    {{ form_row(form.priceD, {label: 'Price D — Range(min: 0, max: 1000)'}) }}
    <button type="submit">Submit</button>
    {{ form_end(form) }}

    {% if submitted %}
        <h2>Result: {{ valid ? '✅ Valid' : '❌ Invalid' }}</h2>
    {% endif %}
{% endblock %}
