{% extends 'base.html.twig' %}

{% block title %}GotenbergBundle — Examples{% endblock %}

{% block body %}
    <div class="container px-4 py-5">
        <h1 class="mb-2">GotenbergBundle Examples</h1>
        <p class="text-muted mb-5">Click on a card to open the generated PDF in a new tab.</p>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <div class="col">
                <a href="{{ path('app_pdf') }}" target="_blank" class="text-decoration-none">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                            <span style="font-size: 3rem;">📄</span>
                            <h5 class="card-title mt-3 text-dark">HTML → PDF</h5>
                            <p class="card-text text-muted text-center">Generate a PDF from a Twig template.</p>
                        </div>
                        <div class="card-footer text-muted small">
                            <code>GET /pdf</code>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="{{ path('app_embed') }}" target="_blank" class="text-decoration-none">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                            <span style="font-size: 3rem;">📎</span>
                            <h5 class="card-title mt-3 text-dark">Embed + Landscape</h5>
                            <p class="card-text text-muted text-center">PDF with embedded files in landscape mode.</p>
                        </div>
                        <div class="card-footer text-muted small">
                            <code>GET /embed</code>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="{{ path('my_pdf') }}" target="_blank" class="text-decoration-none">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                            <span style="font-size: 3rem;">💾</span>
                            <h5 class="card-title mt-3 text-dark">File Processor</h5>
                            <p class="card-text text-muted text-center">Generate and save a PDF to disk.</p>
                        </div>
                        <div class="card-footer text-muted small">
                            <code>GET /processor</code>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
{% endblock %}
