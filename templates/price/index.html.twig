{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <h1>{{ title }}</h1>

    {{ form_start(form) }}
    {{ form_row(form.priceA) }}
    <button type="submit">Submit</button>
    {{ form_end(form) }}

    {% if submitted %}
        <h2>Result: {{ valid ? '✅ Valid' : '❌ Invalid' }}</h2>
    {% endif %}
{% endblock %}
